# OpenAI (default)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optionally override the model (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# OpenRouter (takes precedence over OpenAI when set)
# OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optionally override the model (default: openai/gpt-4o-mini)
# OPENROUTER_MODEL=openai/gpt-4o-mini

# Assistant Cloud API URL -- sign up on cloud.assistant-ui.com
# NEXT_PUBLIC_ASSISTANT_BASE_URL=

# Assistant Cloud API Key
# ASSISTANT_API_KEY=
